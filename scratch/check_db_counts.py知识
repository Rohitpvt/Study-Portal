import asyncio
from sqlalchemy.ext.asyncio import create_async_engine, AsyncSession
from sqlalchemy.orm import sessionmaker
from sqlalchemy import text
import os

# Use the Neon connection string (already modified for asyncpg)
DATABASE_URL = "postgresql+asyncpg://neondb_owner:npg_ay8Z9soWwRrg@ep-tiny-resonance-amripcrp.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require"

async def check_db():
    engine = create_async_engine(DATABASE_URL)
    AsyncSessionLocal = sessionmaker(engine, class_=AsyncSession, expire_on_commit=False)
    
    async with AsyncSessionLocal() as session:
        try:
            # Check users
            users = await session.execute(text("SELECT count(*) FROM users"))
            print(f"Users: {users.scalar()}")
            
            # Check materials
            materials = await session.execute(text("SELECT count(*) FROM materials"))
            print(f"Materials: {materials.scalar()}")
            
            # Check contributions
            contributions = await session.execute(text("SELECT count(*) FROM contributions"))
            print(f"Contributions: {contributions.scalar()}")
            
            # Check contact submissions
            contacts = await session.execute(text("SELECT count(*) FROM contact_submissions"))
            print(f"Contact Submissions: {contacts.scalar()}")
            
        except Exception as e:
            print(f"Error: {e}")
        finally:
            await engine.dispose()

if __name__ == "__main__":
    asyncio.run(check_db())
